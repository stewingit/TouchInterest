local function getSmartName(obj)
    local forbidden = {["Part"]=true, ["Model"]=true, ["Union"]=true, ["UnionOperation"]=true, ["MeshPart"]=true, ["WedgePart"]=true, ["TrussPart"]=true, ["CornerWedgePart"]=true, ["Workspace"]=true}
    if typeof(obj) == "string" then return obj end
    if not forbidden[obj.Name] then return obj.Name end
    local pathParts = obj:GetFullName():split(".")
    for i = #pathParts - 1, 1, -1 do
        local name = pathParts[i]
        if not forbidden[name] then return name .. " (" .. obj.ClassName:gsub("Operation", "") .. ")" end
    end
    return obj.Name
end

