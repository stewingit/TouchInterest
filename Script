local function hook(p)
	if p:IsA("BasePart") then
		local conn = p.Touched:Connect(function(hit)
            if isPaused then return end
			local char = localPlayer.Character
			if not char or not hit:IsDescendantOf(char) then return end
			local pPath = p:GetFullName()
			if pPath == lastLoggedPath then return end
			if loggedParts[pPath] and tick() - loggedParts[pPath] < COOLDOWN_TIME then return end
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum and (hit.Name:find("Leg") or hit.Name:find("Foot")) and (hum:GetState() == Enum.HumanoidStateType.Running or hum:GetState() == Enum.HumanoidStateType.RunningNoPhysics) then return end
			if p:FindFirstAncestorOfClass("Model") and p:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") then return end
			if p.Name == "Baseplate" or p:IsA("Terrain") then return end
			lastLoggedPath = pPath; loggedParts[pPath] = tick()
            
			createEntry(pPath, p, hit.Name, false, liveLogOrder)
		end)
        table.insert(scriptConnections, conn)
	end
end

for _, item in ipairs(workspace:GetDescendants()) do hook(item) end
table.insert(scriptConnections, workspace.DescendantAdded:Connect(hook))
